    {
      "id": "k0000000-0000-0000-0000-000000000013",
      "name": "Strip Mention",
      "type": "n8n-nodes-base.code",
      "position": [
        40,
        320
      ],
      "parameters": {
        "jsCode": "const text = ($json.event?.text || '').replace(/<@[^>]+>/g, '').trim();\nreturn [{ json: { question: text, channel: $json.event.channel, threadTs: $json.event.thread_ts || $json.event.ts } }];"
      },
      "typeVersion": 2
    },
